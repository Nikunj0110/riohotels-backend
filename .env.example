# Required on Railway. Example:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/riohotels?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=riohotels
PORT=4000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
# Use production on Railway.
NODE_ENV=development
WHATSAPP_ENABLED=true
WHATSAPP_CLIENT_ID=riohotels
WHATSAPP_DEFAULT_COUNTRY_CODE=91
# Leave empty on Railway to auto-use RAILWAY_VOLUME_MOUNT_PATH/whatsapp-sessions.
WHATSAPP_SESSIONS_DIR=
# Optional override when using a system Chrome/Chromium instead of @sparticuz/chromium.
WHATSAPP_PUPPETEER_EXECUTABLE_PATH=
WHATSAPP_SEND_DELAY_MIN_MS=3000
WHATSAPP_SEND_DELAY_MAX_MS=7000
WHATSAPP_QUEUE_POLL_INTERVAL_MS=15000
WHATSAPP_QUEUE_RETRY_BASE_MS=60000
WHATSAPP_QUEUE_RETRY_MAX_MS=1800000
WHATSAPP_QUEUE_LOCK_TTL_MS=120000
WHATSAPP_QUEUE_MAX_ATTEMPTS=6
WHATSAPP_SESSION_RM_MAX_RETRIES=4
LOG_LEVEL=info
