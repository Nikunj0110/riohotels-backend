# Required on Railway. Example:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/riohotels?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=riohotels
PORT=4000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=gir@123
# Use production on Railway.
NODE_ENV=development
WHATSAPP_ENABLED=true
WHATSAPP_CLIENT_ID=riohotels
WHATSAPP_DEFAULT_COUNTRY_CODE=91
# Temporary local workspace used by whatsapp-web.js RemoteAuth runtime files.
# On Railway without a volume, /tmp/riohotels-wwebjs_auth is used automatically.
WHATSAPP_SESSIONS_DIR=
# Optional RemoteAuth backup sync interval in milliseconds. Minimum 60000.
WHATSAPP_REMOTE_AUTH_BACKUP_SYNC_INTERVAL_MS=300000
# Optional override when using a specific system Chrome/Chromium path.
WHATSAPP_PUPPETEER_EXECUTABLE_PATH=
WHATSAPP_SEND_DELAY_MIN_MS=3000
WHATSAPP_SEND_DELAY_MAX_MS=7000
LOG_LEVEL=info
